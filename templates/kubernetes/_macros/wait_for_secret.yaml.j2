{% macro wait_for_secret(name, namespace, keys, sync_wave='-5') %}
{% set rbac_wave = sync_wave | string %}
{% set job_wave = (sync_wave | int + 1) | string %}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: wait-for-{{ name }}
  namespace: {{ namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "{{ rbac_wave }}"
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: wait-for-{{ name }}
  namespace: {{ namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "{{ rbac_wave }}"
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["{{ name }}"]
    verbs: ["get"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: wait-for-{{ name }}
  namespace: {{ namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "{{ rbac_wave }}"
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: wait-for-{{ name }}
subjects:
  - kind: ServiceAccount
    name: wait-for-{{ name }}
    namespace: {{ namespace }}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: wait-for-{{ name }}
  namespace: {{ namespace }}
  annotations:
    # Job runs in the wave AFTER its RBAC so SA/Role/RoleBinding are guaranteed
    # committed before the pod starts (avoids 403 Forbidden race).
    argocd.argoproj.io/sync-wave: "{{ job_wave }}"
spec:
  # backoffLimit=2 tolerates transient pod failures (image-pull flakes,
  # first-boot Cilium policy enforcement hiccups) without blocking the sync.
  backoffLimit: 2
  activeDeadlineSeconds: 300
  ttlSecondsAfterFinished: 300
  template:
    metadata:
      labels:
        app.kubernetes.io/name: wait-for-{{ name }}
    spec:
      serviceAccountName: wait-for-{{ name }}
      restartPolicy: Never
      containers:
        - name: wait
          image: bitnami/kubectl:1.30.4
          command:
            - /bin/sh
            - -ec
            - |
              SECRET="{{ name }}"
              NS="{{ namespace }}"
              KEYS="{{ keys | join(' ') }}"
              echo "Waiting for Secret ${NS}/${SECRET} to exist..."
              until kubectl get secret "${SECRET}" -n "${NS}" >/dev/null 2>&1; do
                sleep 2
              done
              echo "Secret exists. Waiting for required keys: ${KEYS}"
              for KEY in ${KEYS}; do
                # Bracket notation so hyphenated key names work. Dot notation
                # (kubectl's Go jsonpath) treats '-' as subtraction.
                until [ -n "$(kubectl get secret "${SECRET}" -n "${NS}" -o jsonpath="{.data['${KEY}']}")" ]; do
                  sleep 2
                done
                echo "  - ${KEY} populated"
              done
              echo "All required keys present. Proceeding."
{% endmacro %}
