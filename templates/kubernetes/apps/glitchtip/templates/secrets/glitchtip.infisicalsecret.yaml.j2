{% import '_macros/wait_for_secret.yaml.j2' as waitmacro %}
---
apiVersion: secrets.infisical.com/v1alpha1
kind: InfisicalSecret
metadata:
  name: glitchtip-secrets
  namespace: {{ glitchtip_namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "-10"
  labels:
    app.kubernetes.io/managed-by: infisical-operator
spec:
  hostAPI: {{ infisical_internal_url }}/api
  syncConfig:
    resyncInterval: 60s
  authentication:
    kubernetesAuth:
      identityId: {{ infisical_operator_identity_id }}
      autoCreateServiceAccountToken: true
      serviceAccountRef:
        name: {{ infisical_operator_service_account }}
        namespace: {{ infisical_operator_namespace }}
      secretsScope:
        projectSlug: {{ infisical_project_slug }}
        envSlug: {{ infisical_env_slug }}
        secretsPath: /kubernetes/glitchtip
        recursive: false
  managedKubeSecretReferences:
    - secretName: glitchtip-secrets
      secretNamespace: {{ glitchtip_namespace }}
      secretType: Opaque
      creationPolicy: Owner
      # Raw components come verbatim via includeAllSecrets; composed URLs are
      # rendered at reconcile time from those raw values.
      #
      # !!! ROTATION CONSTRAINT !!!
      # POSTGRES_PASSWORD and REDIS_PASSWORD are interpolated into URLs below
      # without URL-encoding. Current values are hex so this is safe, but any
      # future rotation MUST produce alphanumeric-only passwords. Characters
      # `:`, `@`, `/`, `?`, `#`, `%` would corrupt DATABASE_URL/REDIS_URL and
      # break glitchtip connectivity. See previous seal_secret template's
      # `urlencode` filter for the pre-A.9 behavior being deliberately simplified.
      template:
        includeAllSecrets: true
        data:
{% raw %}          # Double-escape gotcha: this chart is rendered by Helm first, THEN
          # handed to the Infisical operator. Helm would otherwise consume
          # `{{ .KEY }}` in its own context (missing key → empty). The backtick
          # form is Helm's pass-through literal — it emits `{{ .KEY.Value }}`
          # verbatim into the applied manifest, where the operator's Go template
          # engine evaluates it. `.Value` is the accessor the operator v0.10.32
          # exposes (verified empirically; the plan examples omitted it).
{% endraw %}          DATABASE_URL: {% raw %}'{{ `postgresql://{{ .POSTGRES_USER.Value }}:{{ .POSTGRES_PASSWORD.Value }}@{{ .DB_HOST.Value }}:{{ .DB_PORT.Value }}/{{ .POSTGRES_DB.Value }}` }}'{% endraw %}
          MAINTENANCE_DATABASE_URL: {% raw %}'{{ `postgresql://{{ .POSTGRES_USER.Value }}:{{ .POSTGRES_PASSWORD.Value }}@{{ .DB_HOST.Value }}:{{ .DB_PORT.Value }}/{{ .POSTGRES_DB.Value }}` }}'{% endraw %}
          REDIS_URL: {% raw %}'{{ `redis://:{{ .REDIS_PASSWORD.Value }}@{{ .DB_HOST.Value }}:{{ .REDIS_PORT.Value }}/0` }}'{% endraw %}
{{ waitmacro.wait_for_secret(
     name='glitchtip-secrets',
     namespace=glitchtip_namespace,
     keys=['SECRET_KEY', 'DATABASE_URL', 'MAINTENANCE_DATABASE_URL', 'REDIS_URL', 'EMAIL_URL', 'ADMIN_USERNAME', 'ADMIN_EMAIL', 'ADMIN_PASSWORD', 'BOOTSTRAP_MCP_TOKEN']
   ) }}
