---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: glitchtip-duckdb
  namespace: {{ glitchtip_namespace }}
  annotations:
    # Long-lived PVC: NOT a hook. Hook lifecycle (BeforeHookCreation delete
    # policy) was deleting+recreating this on every sync, racing the
    # pvc-protection finalizer and risking data loss when pods restarted.
    argocd.argoproj.io/sync-wave: "-1"
    argocd.argoproj.io/sync-options: Prune=false
    argocd.argoproj.io/compare-options: IgnoreExtraneous
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: nfs-csi
  resources:
    requests:
      storage: {{ glitchtip_duckdb_storage_size }}