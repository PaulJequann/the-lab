---
glitchtip:
  image:
    repository: glitchtip/glitchtip
    tag: 6.0.10

  extraEnvVars:
    - name: EMAIL_URL
      valueFrom:
        secretKeyRef:
          name: glitchtip-secrets
          key: EMAIL_URL
    - name: DEFAULT_FROM_EMAIL
      valueFrom:
        secretKeyRef:
          name: glitchtip-secrets
          key: DEFAULT_FROM_EMAIL
    - name: GLITCHTIP_ENABLE_MCP
      value: "{{ 'true' if glitchtip_enable_mcp else 'false' }}"
    - name: GLITCHTIP_ENABLE_LOGS
      value: "{{ 'true' if glitchtip_enable_logs else 'false' }}"
    - name: GLITCHTIP_UPTIME_ALLOW_PRIVATE_IPS
      value: "{{ 'true' if glitchtip_uptime_allow_private_ips else 'false' }}"
    - name: GLITCHTIP_RETENTION_DAYS
      value: "{{ glitchtip_retention_days }}"
    - name: GLITCHTIP_TRANSACTION_RETENTION_DAYS
      value: "{{ glitchtip_transaction_retention_days }}"
    - name: GLITCHTIP_LOG_RETENTION_DAYS
      value: "{{ glitchtip_log_retention_days }}"
    - name: GLITCHTIP_FILE_RETENTION_DAYS
      value: "{{ glitchtip_file_retention_days }}"
    - name: GLITCHTIP_ENABLE_DUCKDB
      value: "{{ 'true' if glitchtip_enable_duckdb else 'false' }}"
    - name: GLITCHTIP_COLD_STORAGE_DIR
      value: "{{ glitchtip_duckdb_cold_storage_dir }}"
    - name: DUCKDB_MEMORY_LIMIT
      value: "{{ glitchtip_duckdb_memory_limit }}"
    - name: DUCKDB_TEMP_DIRECTORY
      value: "{{ glitchtip_duckdb_temp_directory }}"

  extraVolumes:
    - name: duckdb-cold-storage
      persistentVolumeClaim:
        claimName: glitchtip-duckdb

  extraVolumeMounts:
    - name: duckdb-cold-storage
      mountPath: {{ glitchtip_duckdb_cold_storage_dir }}

  glitchtip:
    domain: "https://{{ glitchtip_domain }}"
    existingSecret: glitchtip-secrets
    existingSecretKey: SECRET_KEY
    database:
      existingSecret: glitchtip-secrets
      existingSecretKey: DATABASE_URL
    maintenanceDatabase:
      existingSecret: glitchtip-secrets
      existingSecretKey: MAINTENANCE_DATABASE_URL
    valkey:
      existingSecret: glitchtip-secrets
      existingSecretKey: REDIS_URL

  migrationJob:
    enabled: true
    database:
      existingSecret: glitchtip-secrets
      existingSecretKey: MAINTENANCE_DATABASE_URL

  web:
    replicaCount: 1
    ingress:
      enabled: true
      className: cilium
      annotations:
        cert-manager.io/cluster-issuer: {{ cert_manager_issuer_name }}
      hosts:
        - host: {{ glitchtip_domain }}
          paths:
            - path: /
              pathType: Prefix
      tls:
        - secretName: glitchtip-tls
          hosts:
            - {{ glitchtip_domain }}

  worker:
    enabled: true
    replicaCount: 1
    database:
      existingSecret: glitchtip-secrets
      existingSecretKey: MAINTENANCE_DATABASE_URL

  valkey:
    enabled: false

  postgresql:
    enabled: false

  tests:
    configuration:
      enabled: false
