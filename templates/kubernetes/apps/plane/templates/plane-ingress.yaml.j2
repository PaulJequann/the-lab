---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ plane_release_name }}
  namespace: {{ plane_namespace }}
  annotations:
    cert-manager.io/cluster-issuer: {{ cert_manager_issuer_name }}
spec:
  ingressClassName: cilium
  tls:
    - hosts:
        - {{ plane_domain }}
      secretName: plane-tls
  rules:
    - host: {{ plane_domain }}
      http:
        paths:
          - path: /marketplace/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-api
                port:
                  number: 8000
          - path: /graphql/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-api
                port:
                  number: 8000
          - path: /god-mode/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-admin
                port:
                  number: 3000
          - path: /spaces/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-space
                port:
                  number: 3000
          - path: /uploads/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-minio
                port:
                  number: 9000
          - path: /uploads
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-minio
                port:
                  number: 9000
          - path: /auth/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-api
                port:
                  number: 8000
          - path: /live/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-live
                port:
                  number: 3000
          - path: /silo/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-silo
                port:
                  number: 3000
          - path: /api/
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-api
                port:
                  number: 8000
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ plane_release_name }}-web
                port:
                  number: 3000
