{% import '_macros/wait_for_secret.yaml.j2' as waitmacro %}
---
apiVersion: secrets.infisical.com/v1alpha1
kind: InfisicalSecret
metadata:
  name: deeptutor-secrets
  namespace: {{ deeptutor_namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "-10"
  labels:
    app.kubernetes.io/managed-by: infisical-operator
spec:
  hostAPI: {{ infisical_internal_url }}/api
  syncConfig:
    resyncInterval: 60s
  authentication:
    kubernetesAuth:
      identityId: {{ infisical_operator_identity_id }}
      autoCreateServiceAccountToken: true
      serviceAccountRef:
        name: {{ infisical_operator_service_account }}
        namespace: {{ infisical_operator_namespace }}
      secretsScope:
        projectSlug: {{ infisical_project_slug }}
        envSlug: {{ infisical_env_slug }}
        secretsPath: /kubernetes/deeptutor
        recursive: false
  managedKubeSecretReferences:
    - secretName: deeptutor-secrets
      secretNamespace: {{ deeptutor_namespace }}
      secretType: Opaque
      creationPolicy: Owner
      template:
        includeAllSecrets: true
{{ waitmacro.wait_for_secret(
     name='deeptutor-secrets',
     namespace=deeptutor_namespace,
     keys=['LLM_BINDING_API_KEY', 'EMBEDDING_BINDING_API_KEY', 'PERPLEXITY_API_KEY']
   ) }}
