apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ homeassistant_fast_local_claim_name }}
  namespace: {{ homeassistant_namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: {{ fast_local_storage_class_name }}
  resources:
    requests:
      storage: {{ homeassistant_storage_size }}
