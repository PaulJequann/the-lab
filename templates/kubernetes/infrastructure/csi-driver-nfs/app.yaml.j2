apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  # Inner Helm Application (named *-helm to avoid colliding with the outer
  # csi-driver-nfs Application that the cluster-apps ApplicationSet creates
  # from this directory's basename).
  name: csi-driver-nfs-helm
  namespace: {{ argocd_namespace | default('argocd') }}
  annotations:
    argocd.argoproj.io/sync-wave: "-3"
spec:
  destination:
    namespace: kube-system
    server: https://kubernetes.default.svc
  project: infrastructure
  source:
    chart: csi-driver-nfs
    repoURL: https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/master/charts
    targetRevision: {{ csi_driver_nfs_version | default('4.9.0') }}
    helm:
      # Pin release name so existing live resources stay claimed across the
      # rename (was named csi-driver-nfs before this restructure).
      releaseName: csi-driver-nfs
      values: |
        externalSnapshotter:
          enabled: true
        controller:
          runOnControlPlane: true
          replicas: {{ csi_driver_nfs_replica_count | default(2) }}
        storageClass:
          create: true
          name: nfs-csi
          annotations:
            storageclass.kubernetes.io/is-default-class: "true"
          parameters:
            server: {{ nfs_server }}
            share: {{ nfs_export_path }}
          mountOptions:
            - nfsvers=3
            - nolock
          reclaimPolicy: Delete
          volumeBindingMode: Immediate
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true