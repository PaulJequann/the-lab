{% import '_macros/wait_for_secret.yaml.j2' as waitmacro %}
---
apiVersion: secrets.infisical.com/v1alpha1
kind: InfisicalSecret
metadata:
  name: {{ cert_manager_cloudflare_api_secret_name }}
  namespace: {{ cert_manager_namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "-10"
  labels:
    app.kubernetes.io/managed-by: infisical-operator
spec:
  hostAPI: {{ infisical_internal_url }}/api
  syncConfig:
    resyncInterval: 60s
  authentication:
    kubernetesAuth:
      identityId: {{ infisical_operator_identity_id }}
      autoCreateServiceAccountToken: true
      serviceAccountRef:
        name: {{ infisical_operator_service_account }}
        namespace: {{ infisical_operator_namespace }}
      secretsScope:
        projectSlug: {{ infisical_project_slug }}
        envSlug: {{ infisical_env_slug }}
        secretsPath: /kubernetes/cert-manager
        recursive: false
  managedKubeSecretReferences:
    - secretName: {{ cert_manager_cloudflare_api_secret_name }}
      secretNamespace: {{ cert_manager_namespace }}
      secretType: Opaque
      creationPolicy: Owner
      template:
        includeAllSecrets: false
        data:
{% raw %}          # Double-escape gotcha: this chart is rendered by Helm first, THEN
          # handed to the Infisical operator. Helm would otherwise consume
          # `{{ .KEY }}` in its own context (missing key → empty). The backtick
          # form is Helm's pass-through literal — it emits `{{ .KEY.Value }}`
          # verbatim into the applied manifest, where the operator's Go template
          # engine evaluates it. `.Value` is the accessor the operator v0.10.32
          # exposes (verified empirically; the plan examples omitted it).
{% endraw %}          {{ cert_manager_cloudflare_api_secret_key }}: {% raw %}'{{ `{{ .cloudflare_api_token.Value }}` }}'{% endraw %}
{{ waitmacro.wait_for_secret(
     name=cert_manager_cloudflare_api_secret_name,
     namespace=cert_manager_namespace,
     keys=[cert_manager_cloudflare_api_secret_key]
   ) }}
