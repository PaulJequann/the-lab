---
apiVersion: secrets.infisical.com/v1alpha1
kind: InfisicalSecret
metadata:
  name: argocd
  namespace: {{ argocd_namespace }}
  annotations:
    argocd.argoproj.io/sync-wave: "-10"
  labels:
    app.kubernetes.io/managed-by: infisical-operator
spec:
  hostAPI: {{ infisical_internal_url }}/api
  syncConfig:
    resyncInterval: 60s
  authentication:
    kubernetesAuth:
      identityId: {{ infisical_operator_identity_id }}
      autoCreateServiceAccountToken: true
      serviceAccountRef:
        name: {{ infisical_operator_service_account }}
        namespace: {{ infisical_operator_namespace }}
      secretsScope:
        projectSlug: {{ infisical_project_slug }}
        envSlug: {{ infisical_env_slug }}
        secretsPath: /kubernetes/argocd
        recursive: false
  managedKubeSecretReferences:
    - secretName: argocd-secret
      secretNamespace: {{ argocd_namespace }}
      secretType: Opaque
      creationPolicy: Owner
      template:
        includeAllSecrets: false
        data:
          # Double-escape gotcha: this chart is rendered by Helm first, then
          # handed to the Infisical operator. The backtick form is Helm's
          # pass-through literal so the inner operator template emits verbatim
          # into the applied manifest; the operator's own Go-template engine
          # then resolves it via the .Value accessor.
          admin.password: {{ "'{{ `{{ .admin_password_hash.Value }}` }}'" }}
          server.secretkey: {{ "'{{ `{{ .server_secretkey.Value }}` }}'" }}
