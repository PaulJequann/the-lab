---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: cilium-helm
  namespace: {{ argocd_namespace }}
  annotations:
    # Deploy Cilium very early in the process, before other apps
    argocd.argoproj.io/sync-wave: "-10"
spec:
  project: default
  source:
    repoURL: {{ cilium_repo_url }}
    chart: cilium
    targetRevision: {{ cilium_version }}
    helm:
      releaseName: cilium
      values: |
        ingressController:
          enabled: true
          loadbalancerMode: shared
          default: true
          service:
            type: LoadBalancer

        kubeProxyReplacement: "{{ kubeProxyReplacement | lower | string }}"
        hubble:
          relay:
            enabled: {{ hubble_relay_enabled | lower | string }}
          ui:
            enabled: {{ hubble_ui_enabled | lower | string }}

        # IPAM and routing settings
        ipam:
          mode: "cluster-pool"
          operator:
            clusterPoolIPv4PodCIDRList:
              - "{{ cluster_cidr }}"
        
        # Point Cilium to the Kubernetes API
        k8sServiceHost: "{{ control_plane_endpoint }}"
        k8sServicePort: {{ api_port }}
        gatewayAPI:
          enabled: false
        loadBalancer:
          serviceTopology: true
          algorithm: maglev
        operator:
          replicas: 1
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ cilium_namespace }}
  ignoreDifferences:
    # cilium-config data is mutated by the Cilium operator at runtime
    # (cluster identity, BPF feature toggles, etc.)
    - group: ""
      kind: ConfigMap
      name: cilium-config
      namespace: {{ cilium_namespace }}
      jsonPointers:
        - /data
    # cilium-ingress Service is decorated by kube-vip (annotations/labels)
    # and the Service controller (nodePort, loadBalancerIP)
    - group: ""
      kind: Service
      name: cilium-ingress
      namespace: {{ cilium_namespace }}
      jqPathExpressions:
        - '.metadata.annotations["kube-vip.io/loadbalancerIPs"]'
        - '.metadata.annotations["kube-vip.io/vipHost"]'
        - '.metadata.labels.implementation'
        - '.spec.loadBalancerIP'
        - '.spec.allocateLoadBalancerNodePorts'
        - '.spec.ports[].nodePort'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - RespectIgnoreDifferences=true
