---
apiVersion: secrets.infisical.com/v1alpha1
kind: InfisicalSecret
metadata:
  name: grafana-secrets
  namespace: victoria-metrics-stack
  annotations:
    argocd.argoproj.io/sync-wave: "-10"
  labels:
    app.kubernetes.io/managed-by: infisical-operator
spec:
  hostAPI: {{ infisical_internal_url }}/api
  syncConfig:
    resyncInterval: 60s
  authentication:
    kubernetesAuth:
      identityId: {{ infisical_operator_identity_id }}
      autoCreateServiceAccountToken: true
      serviceAccountRef:
        name: {{ infisical_operator_service_account }}
        namespace: {{ infisical_operator_namespace }}
      secretsScope:
        projectSlug: {{ infisical_project_slug }}
        envSlug: {{ infisical_env_slug }}
        secretsPath: /kubernetes/grafana
        recursive: false
  managedKubeSecretReferences:
    - secretName: grafana-secrets
      secretNamespace: victoria-metrics-stack
      secretType: Opaque
      creationPolicy: Owner
      template:
        includeAllSecrets: false
        data:
          POSTGRES_PASSWORD: {{ "'{{ `{{ .POSTGRES_PASSWORD.Value }}` }}'" }}
          DB_HOST: {{ "'{{ `{{ .DB_HOST.Value }}` }}'" }}
          DB_PORT: {{ "'{{ `{{ .DB_PORT.Value }}` }}'" }}
          POSTGRES_USER: {{ "'{{ `{{ .POSTGRES_USER.Value }}` }}'" }}
          POSTGRES_DB: {{ "'{{ `{{ .POSTGRES_DB.Value }}` }}'" }}
          GF_SECURITY_ADMIN_PASSWORD: {{ "'{{ `{{ .GF_SECURITY_ADMIN_PASSWORD.Value }}` }}'" }}
