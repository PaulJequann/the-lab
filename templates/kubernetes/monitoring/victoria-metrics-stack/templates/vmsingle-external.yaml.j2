---
apiVersion: v1
kind: Service
metadata:
  name: vmsingle-external
  namespace: victoria-metrics-stack
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8428
      targetPort: 8428
---
apiVersion: v1
kind: Endpoints
metadata:
  name: vmsingle-external
  namespace: victoria-metrics-stack
subsets:
  - addresses:
      - ip: {{ terraform_service_lxcs['services-data'].ip }}
    ports:
      - name: http
        port: 8428
