---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana
  namespace: victoria-metrics-stack
  annotations:
    cert-manager.io/cluster-issuer: {{ cert_manager_issuer_name }}
spec:
  ingressClassName: cilium
  tls:
    - hosts:
        - {{ grafana_domain }}
      secretName: grafana-tls
  rules:
    - host: {{ grafana_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: victoria-metrics-stack-grafana
                port:
                  number: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vmui
  namespace: victoria-metrics-stack
  annotations:
    cert-manager.io/cluster-issuer: {{ cert_manager_issuer_name }}
spec:
  ingressClassName: cilium
  tls:
    - hosts:
        - {{ vmui_domain }}
      secretName: vmui-tls
  rules:
    - host: {{ vmui_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: vmsingle-external
                port:
                  number: 8428
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: alertmanager
  namespace: victoria-metrics-stack
  annotations:
    cert-manager.io/cluster-issuer: {{ cert_manager_issuer_name }}
spec:
  ingressClassName: cilium
  tls:
    - hosts:
        - {{ alertmanager_domain }}
      secretName: alertmanager-tls
  rules:
    - host: {{ alertmanager_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: vmalertmanager-stack
                port:
                  number: 9093
