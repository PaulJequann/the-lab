---
apiVersion: v1
kind: Service
metadata:
  name: victoria-logs
  namespace: victoria-logs
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 9428
      targetPort: 9428
---
apiVersion: v1
kind: Endpoints
metadata:
  name: victoria-logs
  namespace: victoria-logs
subsets:
  - addresses:
      - ip: {{ terraform_service_lxcs['services-data'].ip }}
    ports:
      - name: http
        port: 9428
