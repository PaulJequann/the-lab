---
all:
  children:
    {{ server_group }}:
      hosts:
        {% for node in node_inventory if node.controller %}
        {{ node.name }}:
          ansible_host: {{ node.address }}
          device_model: {{ node.device_model }}
          network_interface: {{ node.network_interface }}
        {% endfor %}
    services:
      hosts:
        {{ glitchtip_data_hostname }}:
          ansible_host: {{ glitchtip_data_ip }}
          device_model: lxc
        {{ honcho_hostname }}:
          ansible_host: {{ honcho_ip }}
          device_model: lxc
    {{ agent_group }}:
      hosts:
        {% for node in node_inventory if not node.controller %}
        {{ node.name }}:
          ansible_host: {{ node.address }}
          device_model: {{ node.device_model }}
          network_interface: {{ node.network_interface }}
        {% endfor %}