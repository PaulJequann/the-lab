---
ansible_python_interpreter: /usr/bin/python3
ansible_user: {{ ansible_user }}
bootstrap_admin_user: "pj"
control_plane_endpoint: {{ control_plane_endpoint }}
# Infisical connection parameters used by infisical.vault lookups across roles.
# Values rendered from config.yaml; credentials (INFISICAL_CLIENT_ID/SECRET)
# come from scripts/load-bootstrap-secrets.sh ansible.
infisical_project_id: {{ infisical_project_id }}
infisical_env_slug: {{ infisical_env_slug }}
infisical_domain: {{ infisical_domain }}
