resource "proxmox_lxc" "honcho" {
  target_node = "{{ honcho_target_node }}"

  hostname        = "{{ honcho_hostname }}"
  ostemplate      = var.template_name
  password        = var.cipassword
  unprivileged    = true
  ssh_public_keys = file(var.ssh_key_file)
  onboot          = true
  start           = true

  cores  = {{ honcho_cores }}
  memory = {{ honcho_memory_mb }}
  swap   = {{ honcho_swap_mb }}

  rootfs {
    storage = "{{ honcho_storage }}"
    size    = "{{ honcho_disk_size }}"
  }

  network {
    name   = "eth0"
    bridge = "vmbr0"
    gw     = "{{ honcho_gateway }}"
    ip     = "{{ honcho_ip }}/24"
  }

  nameserver = "{{ dns_servers[0] }}"
}

resource "unifi_user" "honcho" {
  allow_existing         = true
  name                   = "{{ honcho_hostname }}"
  mac                    = proxmox_lxc.honcho.network[0].hwaddr
  fixed_ip               = "{{ honcho_ip }}"
  network_id             = "{{ unifi_network_id }}"
  skip_forget_on_destroy = true
}