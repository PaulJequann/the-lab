strict_env

export KUBECONFIG="$PWD/kubeconfig"

watch_file Taskfile.yml
watch_file ansible/requirements.txt
watch_file ansible/requirements.yml
watch_file .envrc.local

ANSIBLE_VENV="$HOME/.venvs/the-lab"

if [[ -x "$ANSIBLE_VENV/bin/ansible" ]]; then
  export VIRTUAL_ENV="$ANSIBLE_VENV"
  PATH_add "$VIRTUAL_ENV/bin"
else
  log_status "missing Ansible venv at $ANSIBLE_VENV"
fi

source_env_if_exists .envrc.local
