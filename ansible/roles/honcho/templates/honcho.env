SUMMARY_MESSAGES_PER_LONG_SUMMARY={{ honcho_summary_messages_per_long_summary | quote }}

# ---- Dream (deduction + induction specialists, no primary in main) ---------
DREAM_ENABLED={{ ('true' if honcho_dream_enabled else 'false') | quote }}
DREAM_MAX_TOOL_ITERATIONS={{ honcho_dream_max_tool_iterations | quote }}
