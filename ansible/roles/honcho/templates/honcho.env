
# -----------------------------------------------------------------------------
# Honcho runtime environment
# Rendered from templates/ansible/roles/honcho/templates/honcho.env.j2
# Schema targets Honcho main branch (post-#459 MODEL_CONFIG refactor).
# -----------------------------------------------------------------------------

# ---- Application ------------------------------------------------------------
LOG_LEVEL={{ honcho_log_level | quote }}
NAMESPACE={{ honcho_namespace | quote }}
SESSION_OBSERVERS_LIMIT={{ honcho_session_observers_limit | quote }}
GET_CONTEXT_MAX_TOKENS={{ honcho_get_context_max_tokens | quote }}
MAX_MESSAGE_SIZE={{ honcho_max_message_size | quote }}
MAX_FILE_SIZE={{ honcho_max_file_size | quote }}
EMBED_MESSAGES={{ ('true' if honcho_embed_messages else 'false') | quote }}
{% if honcho_langfuse_host %}
LANGFUSE_HOST={{ honcho_langfuse_host | quote }}
{% endif %}
{% if honcho_langfuse_public_key %}
LANGFUSE_PUBLIC_KEY={{ honcho_langfuse_public_key | quote }}
{% endif %}
COLLECT_METRICS_LOCAL={{ ('true' if honcho_collect_metrics_local else 'false') | quote }}
LOCAL_METRICS_FILE={{ honcho_local_metrics_file | quote }}
REASONING_TRACES_FILE={{ honcho_reasoning_traces_file | quote }}

# ---- Database ---------------------------------------------------------------
DB_CONNECTION_URI={{ ('postgresql+psycopg://{}:{}@127.0.0.1:{}/{}'.format(honcho_postgres_user, honcho_postgres_password, honcho_postgres_port, honcho_postgres_db)) | quote }}
DB_SCHEMA={{ honcho_db_schema | quote }}
DB_POOL_CLASS={{ honcho_db_pool_class | quote }}
DB_POOL_PRE_PING={{ ('true' if honcho_db_pool_pre_ping else 'false') | quote }}
DB_POOL_SIZE={{ honcho_db_pool_size | quote }}
DB_MAX_OVERFLOW={{ honcho_db_max_overflow | quote }}
DB_POOL_TIMEOUT={{ honcho_db_pool_timeout | quote }}
DB_POOL_RECYCLE={{ honcho_db_pool_recycle | quote }}
DB_POOL_USE_LIFO={{ ('true' if honcho_db_pool_use_lifo else 'false') | quote }}
DB_SQL_DEBUG={{ ('true' if honcho_db_sql_debug else 'false') | quote }}
DB_TRACING={{ ('true' if honcho_db_tracing else 'false') | quote }}

# ---- Auth -------------------------------------------------------------------
AUTH_USE_AUTH={{ ('true' if honcho_auth_use_auth else 'false') | quote }}
AUTH_JWT_SECRET={{ honcho_auth_jwt_secret | quote }}

# ---- Cache (Redis) ----------------------------------------------------------
CACHE_ENABLED={{ ('true' if honcho_cache_enabled else 'false') | quote }}
CACHE_URL={{ ('redis://:{}@127.0.0.1:{}/0'.format(honcho_redis_password, honcho_redis_port)) | quote }}
CACHE_NAMESPACE={{ honcho_cache_namespace | quote }}
CACHE_DEFAULT_TTL_SECONDS={{ honcho_cache_default_ttl_seconds | quote }}
CACHE_DEFAULT_LOCK_TTL_SECONDS={{ honcho_cache_default_lock_ttl_seconds | quote }}

# ---- LLM (API keys + top-level token limits) --------------------------------
LLM_DEFAULT_MAX_TOKENS={{ honcho_llm_default_max_tokens | quote }}
LLM_MAX_TOOL_OUTPUT_CHARS={{ honcho_llm_max_tool_output_chars | quote }}
LLM_MAX_MESSAGE_CONTENT_CHARS={{ honcho_llm_max_message_content_chars | quote }}
LLM_ANTHROPIC_API_KEY={{ honcho_llm_anthropic_api_key | quote }}
LLM_OPENAI_API_KEY={{ honcho_llm_openai_api_key | quote }}
LLM_GEMINI_API_KEY={{ honcho_llm_gemini_api_key | quote }}

# ---- Embedding --------------------------------------------------------------
EMBEDDING_MODEL_CONFIG__TRANSPORT={{ honcho_embedding_transport | quote }}
EMBEDDING_MODEL_CONFIG__MODEL={{ honcho_embedding_model | quote }}
EMBEDDING_VECTOR_DIMENSIONS={{ honcho_embedding_vector_dimensions | quote }}
EMBEDDING_MAX_INPUT_TOKENS={{ honcho_embedding_max_input_tokens | quote }}
EMBEDDING_MAX_TOKENS_PER_REQUEST={{ honcho_embedding_max_tokens_per_request | quote }}

# ---- Dialectic --------------------------------------------------------------
DIALECTIC_MAX_OUTPUT_TOKENS={{ honcho_dialectic_max_output_tokens | quote }}
DIALECTIC_MAX_INPUT_TOKENS={{ honcho_dialectic_max_input_tokens | quote }}
DIALECTIC_HISTORY_TOKEN_LIMIT={{ honcho_dialectic_history_token_limit | quote }}
DIALECTIC_SESSION_HISTORY_MAX_TOKENS={{ honcho_dialectic_session_history_max_tokens | quote }}

# -- minimal level --
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__TRANSPORT={{ honcho_dialectic_minimal_transport | quote }}
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL={{ honcho_dialectic_minimal_model | quote }}
