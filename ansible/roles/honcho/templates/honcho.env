DREAM_DEDUCTION_MODEL_CONFIG__TRANSPORT={{ honcho_dream_deduction_transport | quote }}
DREAM_DEDUCTION_MODEL_CONFIG__MODEL={{ honcho_dream_deduction_model | quote }}
