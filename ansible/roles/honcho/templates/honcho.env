SUMMARY_MODEL_CONFIG__FALLBACK__MODEL={{ honcho_summary_fallback_model | quote }}
{% endif %}
SUMMARY_MAX_TOKENS_SHORT={{ honcho_summary_max_tokens_short | quote }}
