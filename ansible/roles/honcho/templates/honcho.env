{% if honcho_dialectic_minimal_tool_choice %}
DIALECTIC_LEVELS__minimal__TOOL_CHOICE={{ honcho_dialectic_minimal_tool_choice | quote }}
{% endif %}

# -- low level --
DIALECTIC_LEVELS__low__MODEL_CONFIG__TRANSPORT={{ honcho_dialectic_low_transport | quote }}
DIALECTIC_LEVELS__low__MODEL_CONFIG__MODEL={{ honcho_dialectic_low_model | quote }}
DIALECTIC_LEVELS__low__MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_dialectic_low_thinking_budget_tokens | quote }}
DIALECTIC_LEVELS__low__MAX_TOOL_ITERATIONS={{ honcho_dialectic_low_max_tool_iterations | quote }}
{% if honcho_dialectic_low_tool_choice %}
DIALECTIC_LEVELS__low__TOOL_CHOICE={{ honcho_dialectic_low_tool_choice | quote }}
{% endif %}

# -- medium level --
DIALECTIC_LEVELS__medium__MODEL_CONFIG__TRANSPORT={{ honcho_dialectic_medium_transport | quote }}
DIALECTIC_LEVELS__medium__MODEL_CONFIG__MODEL={{ honcho_dialectic_medium_model | quote }}
DIALECTIC_LEVELS__medium__MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_dialectic_medium_thinking_budget_tokens | quote }}
DIALECTIC_LEVELS__medium__MAX_TOOL_ITERATIONS={{ honcho_dialectic_medium_max_tool_iterations | quote }}

# -- high level --
DIALECTIC_LEVELS__high__MODEL_CONFIG__TRANSPORT={{ honcho_dialectic_high_transport | quote }}
DIALECTIC_LEVELS__high__MODEL_CONFIG__MODEL={{ honcho_dialectic_high_model | quote }}
DIALECTIC_LEVELS__high__MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_dialectic_high_thinking_budget_tokens | quote }}
DIALECTIC_LEVELS__high__MAX_TOOL_ITERATIONS={{ honcho_dialectic_high_max_tool_iterations | quote }}

# -- max level --
DIALECTIC_LEVELS__max__MODEL_CONFIG__TRANSPORT={{ honcho_dialectic_max_transport | quote }}
DIALECTIC_LEVELS__max__MODEL_CONFIG__MODEL={{ honcho_dialectic_max_model | quote }}
DIALECTIC_LEVELS__max__MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_dialectic_max_thinking_budget_tokens | quote }}
DIALECTIC_LEVELS__max__MAX_TOOL_ITERATIONS={{ honcho_dialectic_max_max_tool_iterations | quote }}
{% if honcho_dialectic_max_fallback_transport and honcho_dialectic_max_fallback_model %}
DIALECTIC_LEVELS__max__MODEL_CONFIG__FALLBACK__TRANSPORT={{ honcho_dialectic_max_fallback_transport | quote }}
DIALECTIC_LEVELS__max__MODEL_CONFIG__FALLBACK__MODEL={{ honcho_dialectic_max_fallback_model | quote }}
{% endif %}

# ---- Deriver ----------------------------------------------------------------
DERIVER_ENABLED={{ ('true' if honcho_deriver_enabled else 'false') | quote }}
DERIVER_WORKERS={{ honcho_deriver_workers | quote }}
DERIVER_MODEL_CONFIG__TRANSPORT={{ honcho_deriver_transport | quote }}
DERIVER_MODEL_CONFIG__MODEL={{ honcho_deriver_model | quote }}
DERIVER_MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_deriver_thinking_budget_tokens | quote }}
DERIVER_MODEL_CONFIG__MAX_OUTPUT_TOKENS={{ honcho_deriver_max_output_tokens | quote }}
{% if honcho_deriver_temperature is not none and (honcho_deriver_temperature | string | trim) != '' %}
DERIVER_MODEL_CONFIG__TEMPERATURE={{ honcho_deriver_temperature | quote }}
{% endif %}
{% if honcho_deriver_fallback_transport and honcho_deriver_fallback_model %}
DERIVER_MODEL_CONFIG__FALLBACK__TRANSPORT={{ honcho_deriver_fallback_transport | quote }}
DERIVER_MODEL_CONFIG__FALLBACK__MODEL={{ honcho_deriver_fallback_model | quote }}
{% endif %}
DERIVER_MAX_INPUT_TOKENS={{ honcho_deriver_max_input_tokens | quote }}
DERIVER_POLLING_SLEEP_INTERVAL_SECONDS={{ honcho_deriver_polling_sleep_interval_seconds | quote }}
DERIVER_STALE_SESSION_TIMEOUT_MINUTES={{ honcho_deriver_stale_session_timeout_minutes | quote }}
DERIVER_QUEUE_ERROR_RETENTION_SECONDS={{ honcho_deriver_queue_error_retention_seconds | quote }}
DERIVER_DEDUPLICATE={{ ('true' if honcho_deriver_deduplicate else 'false') | quote }}
DERIVER_LOG_OBSERVATIONS={{ ('true' if honcho_deriver_log_observations else 'false') | quote }}
DERIVER_WORKING_REPRESENTATION_MAX_OBSERVATIONS={{ honcho_deriver_working_representation_max_observations | quote }}
DERIVER_REPRESENTATION_BATCH_MAX_TOKENS={{ honcho_deriver_representation_batch_max_tokens | quote }}
DERIVER_FLUSH_ENABLED={{ ('true' if honcho_deriver_flush_enabled else 'false') | quote }}

# ---- Peer Card --------------------------------------------------------------
PEER_CARD_ENABLED={{ ('true' if honcho_peer_card_enabled else 'false') | quote }}

# ---- Summary ----------------------------------------------------------------
SUMMARY_ENABLED={{ ('true' if honcho_summary_enabled else 'false') | quote }}
SUMMARY_MODEL_CONFIG__TRANSPORT={{ honcho_summary_transport | quote }}
SUMMARY_MODEL_CONFIG__MODEL={{ honcho_summary_model | quote }}
SUMMARY_MODEL_CONFIG__THINKING_BUDGET_TOKENS={{ honcho_summary_thinking_budget_tokens | quote }}
{% if honcho_summary_fallback_transport and honcho_summary_fallback_model %}
