global:
  domain: {{ argocd_domain }}
configs:
  cm:
    create: true
    admin.enabled: true
    application.instanceLabelKey: app.kubernetes.io/instance
    resource.exclusions: |
      - apiGroups:
          - ""
        kinds:
          - Secret
        clusters:
          - "*"
        labelSelector:
          matchLabels:
            app.kubernetes.io/managed-by: infisical-operator
  params:
    create: true
    server.insecure: {{ argocd_insecure | default(false) | to_json }}
  # argocd-secret is materialized by an InfisicalSecret inside the
  # kubernetes/core/argocd/ chart at selfHeal time. The Ansible role
  # plants the initial Secret before this Helm install runs so that
  # argocd-server can boot on a fresh cluster (see tasks/main.yaml).
  secret:
    create: false
server:
  service:
    type: ClusterIP
repoServer:
  serviceAccount:
    create: true
    name: argocd-repo-server
  rbac:
    - apiGroups:
        - ""
      resources:
        - secrets
      verbs:
        - get
